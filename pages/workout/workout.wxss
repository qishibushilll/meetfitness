.icon-button {
  flex: 0 0 72rpx;
  width: 72rpx;
  min-width: 72rpx;
  height: 60rpx;
  margin: 0;
  padding: 0;
  font-size: 24rpx;
  line-height: 60rpx;
}

.recommend-section {
  margin-bottom: 22rpx;
}

.recommend-head {
  margin-bottom: 12rpx;
}

.link-more {
  flex: 0 0 88rpx;
  width: 88rpx;
  height: 52rpx;
  margin: 0;
  padding: 0;
  background: transparent;
  color: #0f7b6c;
  font-size: 24rpx;
  line-height: 52rpx;
}

.recommend-swiper {
  width: 100%;
  height: 188rpx;
}

.recommend-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  height: 156rpx;
  margin: 0 2rpx;
  padding: 18rpx;
  border: 1rpx solid #e5e9ec;
  border-radius: 10rpx;
  background: #ffffff;
}

.recommend-image {
  display: block;
  flex: 0 0 118rpx;
  width: 118rpx;
  height: 118rpx;
  border-radius: 10rpx;
  background: #eef2f4;
}

.recommend-body {
  flex: 1;
  min-width: 0;
}

.recommend-label {
  color: #0f7b6c;
  font-size: 22rpx;
  font-weight: 700;
}

.recommend-title {
  margin-top: 8rpx;
  color: #1f272e;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.25;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recommend-meta {
  margin-top: 8rpx;
  color: #68717a;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recommend-cta {
  flex: 0 0 76rpx;
  height: 52rpx;
  border-radius: 8rpx;
  background: #eef5f3;
  color: #0f7b6c;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 52rpx;
  text-align: center;
}

.exercise-picker {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-height: 150rpx;
  border: 1rpx solid #d8dee3;
  border-radius: 10rpx;
  padding: 16rpx;
  background: #ffffff;
}

.exercise-picker-image,
.workout-thumb {
  flex: 0 0 112rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 10rpx;
  background: #eef2f4;
}

.exercise-picker-empty {
  flex: 0 0 112rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 10rpx;
  background: #eef5f3;
  color: #0f7b6c;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 112rpx;
  text-align: center;
}

.exercise-picker-body {
  flex: 1;
  min-width: 0;
}

.exercise-picker-action {
  flex: 0 0 72rpx;
  color: #0f7b6c;
  font-size: 24rpx;
  text-align: right;
}

.workout-item-main {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-width: 0;
}

.workout-thumb {
  flex-basis: 82rpx;
  width: 82rpx;
  height: 82rpx;
}
