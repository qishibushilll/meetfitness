.learn-hero {
  margin: -28rpx -28rpx 28rpx;
  padding: 44rpx 28rpx 36rpx;
  background: #152027;
  color: #ffffff;
}

.learn-kicker {
  color: #8fb8ad;
  font-size: 22rpx;
  font-weight: 700;
}

.learn-title {
  margin-top: 8rpx;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.15;
}

.learn-subtitle {
  margin-top: 12rpx;
  color: #c1cbd0;
  font-size: 25rpx;
}

.video-panel {
  padding: 22rpx;
}

.learn-video {
  width: 100%;
  height: 360rpx;
  border-radius: 10rpx;
  background: #101418;
}

.learn-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.learn-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 150rpx;
  padding: 18rpx;
  border: 1rpx solid #e5e9ec;
  border-radius: 12rpx;
  background: #ffffff;
}

.learn-cover {
  flex: 0 0 118rpx;
  width: 118rpx;
  height: 118rpx;
  border-radius: 10rpx;
  background: #eef2f4;
}

.learn-body {
  flex: 1;
  min-width: 0;
}

.learn-card-title {
  color: #1f272e;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.25;
}

.learn-summary,
.learn-meta {
  margin-top: 7rpx;
  color: #68717a;
  font-size: 23rpx;
  line-height: 1.35;
}

.learn-meta {
  color: #8a949c;
}

.learn-button {
  flex: 0 0 86rpx;
  width: 86rpx;
  height: 56rpx;
  margin: 0;
  padding: 0;
  border-radius: 8rpx;
  background: #0f7b6c;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 56rpx;
}

.empty-hint {
  margin-top: 10rpx;
  color: #98a2aa;
  font-size: 23rpx;
}
