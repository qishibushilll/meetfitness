<view class="page">
  <view class="section">
    <view class="title">选择动作</view>
    <view class="subtitle">先选择训练部位，再选择具体动作</view>
  </view>

  <view class="section panel">
    <input
      class="input"
      value="{{keyword}}"
      placeholder="全动作搜索：动作、部位或器械"
      bindinput="onKeywordInput"
      confirm-type="search"
      bindconfirm="searchExercises"
    />
    <button class="secondary-button search-button" bindtap="searchExercises">搜索全部动作</button>
    <button class="link-button submit-entry" bindtap="goSubmitExercise">找不到动作？提交新动作</button>
  </view>

  <view wx:if="{{loading}}" class="panel empty">正在加载动作库</view>

  <view wx:elif="{{errorText}}" class="panel empty">
    <view>{{errorText}}</view>
    <button class="secondary-button retry-button" bindtap="loadMuscleGroups">重试</button>
  </view>

  <view wx:elif="{{mode == 'muscles'}}" class="section">
    <view class="section-title">训练部位</view>
    <view class="muscle-grid">
      <view
        wx:for="{{muscleGroups}}"
        wx:key="name"
        class="muscle-card"
        data-index="{{index}}"
        bindtap="selectMuscle"
      >
        <image
          class="muscle-image"
          src="{{item.coverImageUrl}}"
          mode="aspectFill"
          data-url="{{item.coverImageUrl}}"
          binderror="onImageError"
        />
        <view class="muscle-body">
          <view class="muscle-name">{{item.name}}</view>
          <view class="muscle-footer">
            <view class="muscle-count">{{item.count}} 个动作</view>
            <button class="learn-entry" data-index="{{index}}" catchtap="goLearn">学习</button>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="section">
    <view class="row-between list-header">
      <view>
        <view class="section-title">{{listTitle}}</view>
        <view class="muted">{{exercises.length}} 个动作</view>
      </view>
      <button wx:if="{{showBackButton}}" class="secondary-button back-button" bindtap="backToMuscles">部位</button>
    </view>

    <view wx:if="{{exercises.length}}" class="exercise-grid">
      <view
        wx:for="{{exercises}}"
        wx:key="exerciseId"
        class="exercise-card"
        data-index="{{index}}"
        bindtap="selectExercise"
      >
        <image
          class="exercise-image"
          src="{{item.imageUrl}}"
          mode="aspectFill"
          data-url="{{item.imageUrl}}"
          binderror="onImageError"
        />
        <view class="exercise-card-body">
          <view class="exercise-name">{{item.name}}</view>
          <view wx:if="{{item.showNameEn}}" class="exercise-meta">{{item.nameEn}}</view>
          <view class="exercise-meta">{{item.muscle}}</view>
          <view class="exercise-meta">{{item.equipment}}</view>
        </view>
      </view>
    </view>

    <view wx:else class="panel empty">
      <view>没有找到动作</view>
      <button class="secondary-button retry-button" bindtap="goSubmitExercise">提交新动作</button>
    </view>
  </view>
  <button
    wx:if="{{showBackTop}}"
    class="back-top-button"
    hover-class="back-top-button-active"
    bindtap="scrollToTop"
  >↑</button>
</view>
