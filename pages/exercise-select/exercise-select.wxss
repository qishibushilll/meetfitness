.search-button {
  margin-top: 18rpx;
}

.retry-button {
  margin-top: 22rpx;
}

.list-header {
  margin-bottom: 18rpx;
}

.back-button {
  width: 116rpx;
  min-width: 116rpx;
  height: 64rpx;
  margin: 0;
  font-size: 25rpx;
  line-height: 64rpx;
}

.muscle-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.muscle-card {
  overflow: hidden;
  min-height: 250rpx;
  background: #ffffff;
  border: 1rpx solid #e5e9ec;
  border-radius: 12rpx;
}

.muscle-image {
  display: block;
  width: 100%;
  height: 150rpx;
  background: #eef2f4;
}

.muscle-body {
  padding: 18rpx;
}

.muscle-name {
  color: #1f272e;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.25;
}

.muscle-count {
  margin-top: 8rpx;
  color: #68717a;
  font-size: 24rpx;
}

.exercise-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.exercise-card {
  overflow: hidden;
  min-height: 340rpx;
  background: #ffffff;
  border: 1rpx solid #e5e9ec;
  border-radius: 12rpx;
}

.exercise-image {
  display: block;
  width: 100%;
  height: 220rpx;
  background: #eef2f4;
}

.exercise-card-body {
  padding: 18rpx;
}

.exercise-name {
  color: #1f272e;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.25;
}

.exercise-meta {
  margin-top: 8rpx;
  color: #68717a;
  font-size: 23rpx;
  line-height: 1.3;
}
