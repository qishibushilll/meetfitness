.upload-box {
  width: 100%;
  height: 300rpx;
  overflow: hidden;
  border: 1rpx dashed #cbd3d9;
  border-radius: 10rpx;
  background: #f3f6f7;
}

.upload-image {
  display: block;
  width: 100%;
  height: 100%;
}

.upload-empty {
  height: 300rpx;
  color: #68717a;
  font-size: 28rpx;
  line-height: 300rpx;
  text-align: center;
}

.textarea {
  width: 100%;
  min-height: 180rpx;
  border: 1rpx solid #d8dee3;
  border-radius: 10rpx;
  padding: 18rpx 20rpx;
  background: #ffffff;
  color: #1a1f24;
  font-size: 28rpx;
  line-height: 1.5;
}
