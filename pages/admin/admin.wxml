<view class="page">
  <view class="section">
    <view class="title">数据库维护</view>
    <view class="subtitle">管理员入口</view>
  </view>

  <view wx:if="{{isUserOnly}}" class="panel empty">当前账号不是管理员</view>

  <view wx:else>
    <view class="section panel">
      <view class="metric-grid admin-metrics">
        <view class="metric">
          <view class="metric-value">{{stats.exercises}}</view>
          <view class="metric-label">动作</view>
        </view>
        <view class="metric">
          <view class="metric-value">{{stats.meals}}</view>
          <view class="metric-label">饮食</view>
        </view>
        <view class="metric">
          <view class="metric-value">{{stats.workouts}}</view>
          <view class="metric-label">训练</view>
        </view>
        <view class="metric">
          <view class="metric-value">{{stats.users}}</view>
          <view class="metric-label">用户</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="row-between section-heading">
        <view class="section-title">待审核动作</view>
        <button class="secondary-button refresh-button" loading="{{loading}}" bindtap="loadAdminData">刷新</button>
      </view>

      <view wx:if="{{hasSubmissions}}" class="list">
        <view wx:for="{{submissions}}" wx:key="id" class="list-item review-item">
          <view class="review-main">
            <image class="review-image" src="{{item.imageUrl}}" mode="aspectFill" />
            <view class="review-body">
              <view class="item-title">{{item.name}}</view>
              <view class="item-meta">{{item.muscle}} · {{item.equipment}}</view>
              <view wx:if="{{item.note}}" class="item-meta">{{item.note}}</view>
              <view class="item-meta">提交时间：{{item.createdAtText}}</view>
            </view>
          </view>
          <view class="review-actions">
            <button class="primary-button review-button" data-id="{{item.id}}" bindtap="approveSubmission">通过</button>
            <button class="danger-button review-button" data-id="{{item.id}}" bindtap="rejectSubmission">拒绝</button>
          </view>
        </view>
      </view>

      <view wx:else class="panel empty">暂无待审核动作</view>
    </view>

    <view class="section">
      <view class="section-title">维护模块</view>
      <view class="list">
        <view class="list-item">
          <view class="item-title">动作库 exercises</view>
          <view class="item-meta">维护动作名称、中文字段、肌群、器械和图片</view>
        </view>
        <view class="list-item">
          <view class="item-title">饮食记录 meals</view>
          <view class="item-meta">查看和修正用户饮食数据</view>
        </view>
        <view class="list-item">
          <view class="item-title">训练记录 workouts</view>
          <view class="item-meta">查看和修正用户训练数据</view>
        </view>
        <view class="list-item">
          <view class="item-title">用户 users</view>
          <view class="item-meta">维护用户角色，role 为 admin 时显示管理员入口</view>
        </view>
      </view>
    </view>
  </view>
</view>
