.profile-name {
  color: #1f272e;
  font-size: 34rpx;
  font-weight: 700;
}

.profile-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-width: 0;
}

.avatar {
  flex: 0 0 96rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #eef2f4;
}

.avatar-button {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 18rpx;
  width: 100%;
  height: 104rpx;
  margin: 0;
  padding: 0 20rpx;
  border: 1rpx solid #d8dee3;
  border-radius: 10rpx;
  background: #ffffff;
  color: #27313a;
  font-size: 28rpx;
  line-height: 104rpx;
  text-align: left;
}

.avatar-form {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #eef2f4;
}

.admin-entry {
  border-color: #0f7b6c;
}
