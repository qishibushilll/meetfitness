<view class="page">
  <view class="section">
    <view class="title">我的</view>
    <view class="subtitle">资料和数据入口</view>
  </view>

  <view class="section panel">
    <view class="row-between">
      <view class="profile-head">
        <image class="avatar" src="{{avatarDisplayUrl}}" mode="aspectFill" />
        <view>
          <view class="profile-name">{{displayName}}</view>
          <view class="item-meta">{{accountText}}</view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{isUnregistered}}" class="section panel">
    <view class="section-title">登录</view>
    <view class="form-item">
      <text class="label">头像</text>
      <button class="avatar-button" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image class="avatar-form" src="{{avatarDisplayUrl}}" mode="aspectFill" />
        <text>选择头像</text>
      </button>
    </view>
    <view class="form-item">
      <text class="label">昵称</text>
      <input class="input" value="{{form.nickName}}" placeholder="请输入昵称" bindinput="onNicknameInput" />
    </view>
    <button class="primary-button" loading="{{saving}}" bindtap="saveProfile">完成登录</button>
  </view>

  <view wx:else class="section panel">
    <view class="section-title">资料</view>
    <view class="form-item">
      <text class="label">头像</text>
      <button class="avatar-button" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image class="avatar-form" src="{{avatarDisplayUrl}}" mode="aspectFill" />
        <text>更换头像</text>
      </button>
    </view>
    <view class="form-item">
      <text class="label">昵称</text>
      <input class="input" value="{{form.nickName}}" placeholder="请输入昵称" bindinput="onNicknameInput" />
    </view>
    <button class="secondary-button" loading="{{saving}}" bindtap="saveProfile">保存资料</button>
  </view>

  <view class="section">
    <view class="section-title">常用入口</view>
    <view class="list">
      <view class="list-item" bindtap="goHistory">
        <view class="item-title">我的历史记录</view>
        <view class="item-meta">查看训练和饮食历史汇总</view>
      </view>
      <view class="list-item" bindtap="goWorkout">
        <view class="item-title">记录训练</view>
        <view class="item-meta">添加动作、组数、次数和重量</view>
      </view>
      <view class="list-item" bindtap="goDiet">
        <view class="item-title">记录饮食</view>
        <view class="item-meta">添加餐次、热量和蛋白质</view>
      </view>
    </view>
  </view>

  <view wx:if="{{isAdmin}}" class="section">
    <view class="section-title">工具</view>
    <view class="list">
      <view class="list-item admin-entry" bindtap="goAdmin">
        <view class="item-title">控制台</view>
        <view class="item-meta">维护动作、饮食、训练和用户数据</view>
      </view>
    </view>
  </view>
  <button
    wx:if="{{showBackTop}}"
    class="back-top-button"
    hover-class="back-top-button-active"
    bindtap="scrollToTop"
  >↑</button>
</view>
