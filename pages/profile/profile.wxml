<view class="page">
  <view class="section">
    <view class="title">我的</view>
    <view class="subtitle">账户角色和数据入口</view>
  </view>

  <view class="section panel">
    <view class="row-between">
      <view>
        <view class="profile-name">{{displayName}}</view>
        <view class="item-meta">{{roleText}}</view>
      </view>
      <view class="role-badge">{{roleBadge}}</view>
    </view>
  </view>

  <view wx:if="{{isUnregistered}}" class="section panel">
    <view class="section-title">注册</view>
    <view class="form-item">
      <text class="label">昵称</text>
      <input class="input" value="{{form.nickName}}" placeholder="请输入昵称" bindinput="onNicknameInput" />
    </view>
    <button class="primary-button" loading="{{saving}}" bindtap="saveProfile">完成注册</button>
  </view>

  <view wx:else class="section panel">
    <view class="section-title">资料</view>
    <view class="form-item">
      <text class="label">昵称</text>
      <input class="input" value="{{form.nickName}}" placeholder="请输入昵称" bindinput="onNicknameInput" />
    </view>
    <button class="secondary-button" loading="{{saving}}" bindtap="saveProfile">保存资料</button>
  </view>

  <view class="section">
    <view class="section-title">普通用户</view>
    <view class="list">
      <view class="list-item" bindtap="goHistory">
        <view class="item-title">我的历史记录</view>
        <view class="item-meta">查看训练和饮食历史汇总</view>
      </view>
      <view class="list-item" bindtap="goWorkout">
        <view class="item-title">记录训练</view>
        <view class="item-meta">添加动作、组数、次数和重量</view>
      </view>
      <view class="list-item" bindtap="goDiet">
        <view class="item-title">记录饮食</view>
        <view class="item-meta">添加餐次、热量和蛋白质</view>
      </view>
    </view>
  </view>

  <view wx:if="{{isAdmin}}" class="section">
    <view class="section-title">管理员</view>
    <view class="list">
      <view class="list-item admin-entry" bindtap="goAdmin">
        <view class="item-title">数据库维护</view>
        <view class="item-meta">维护动作、饮食、训练和用户数据</view>
      </view>
    </view>
  </view>
</view>
